# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── JWT ───────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string

# ── Paystack ──────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# ── Email (Resend) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@ztomarketing.com
SMTP_PASS=your-gmail-app-password

# ── App ───────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Your Vercel frontend URL (no trailing slash)
# e.g. https://ztoagency.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# ── Admin seed credentials ─────────────────────────
ADMIN_EMAIL_SEED=your-admin-email@example.com
ADMIN_PASSWORD_SEED=YourStrongPassword@2026!
